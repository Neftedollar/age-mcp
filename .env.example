# ── Docker / PostgreSQL ──
PG_MAJOR=17
AGE_VERSION=1.6.0
DB_PORT=5435
POSTGRES_USER=agemcp
POSTGRES_PASSWORD=agemcp
POSTGRES_DB=agemcp

# ── MCP Server ──
AGE_CONNECTION_STRING=Host=localhost;Port=5435;Database=agemcp;Username=agemcp;Password=agemcp
TENANT_ID=default

# ── Embeddings (optional — for semantic_search / graph_context) ──
# EMBEDDING_API_URL=http://localhost:11434/v1/embeddings
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=384
